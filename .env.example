# ── Aurentis AI — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is in .gitignore and will never be committed.

# ── Dashboard credentials ─────────────────────────────────────────────────
DASHBOARD_USER=aurentis
DASHBOARD_PASS=changeme123

# ── Web server ────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000

# ── Trading parameters ────────────────────────────────────────────────────
INITIAL_CAPITAL=10000
TRADING_PAIRS=BTC,ETH,SOL,DOGE,AVAX,LINK,ARB,WIF
SIGNAL_THRESHOLD=0.24
MAX_POSITIONS=4

# ── Discord alerts (optional) ─────────────────────────────────────────────
# Create a webhook in your Discord server: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# ── Supabase cloud sync (optional) ───────────────────────────────────────
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=eyJ...

# ── Database path ─────────────────────────────────────────────────────────
DB_PATH=aurentis.db
